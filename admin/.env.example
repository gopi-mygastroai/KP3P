# Local setup: cp .env.example .env
# Next.js loads .env / .env.local; Prisma CLI (e.g. prisma generate in npm run build) reads .env.
# Scripts under scripts/ load .env from the project root.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# --- Database (required for Prisma) ---
# Connection string for PostgreSQL (name matches prisma/schema.prisma).
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Direct (non-pooling) connection string — required for `prisma migrate` and `prisma db push`.
# Prisma uses this URL for direct connections that bypass the pooler (migrations, schema introspection).
# On Supabase or Neon, the pooled URL often differs: the pooler listens on port 6543 while the direct
# database uses port 5432 — use the direct host/port here, and drop pooler-only query params (e.g.
# `?pgbouncer=true` on Supabase) so Prisma talks to Postgres natively.
# This variable is required: leaving it blank or wrong commonly makes `prisma migrate` error or appear
# to fail without an obvious cause.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Set to true only when actively debugging SQL queries.
PRISMA_LOG_QUERIES=false
# Optional Prisma pool tuning (helps avoid P2024 pool timeout spikes in dev)
PRISMA_CONNECTION_LIMIT=5
PRISMA_POOL_TIMEOUT=20

# --- Google Gemini (required for /api/generate-caresheet) ---
GEMINI_API_KEY=

# --- Google Drive uploads (optional; /api/drive/upload returns 500 if unset) ---
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_FOLDER_ID=

# --- Scripts only: scripts/test-openrouter.mjs ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# --- Scripts only: scripts/test-generate-care-sheet.mjs ---
BASE_URL=http://localhost:3000
TEST_BASE_URL=
