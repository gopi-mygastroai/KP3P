# KP3P monorepo — admin/ + Patient-intake-form/
# Root patterns apply to all subfolders unless prefixed with /

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build outputs ---
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# --- Local env & secrets (keep *.example templates) ---
.env*
!.env.example
!.env.*.example
.envrc
.direnv/
*.pem
*.key
*.p12
*.pfx
*.keystore
client_secret*.json
*credentials*.json
!**/*credentials*.example.json

# --- Host / deploy ---
.vercel
.netlify
.turbo

# --- Databases (local dev) ---
*.db
*.db-journal
*.sqlite
*.sqlite3

# --- Prisma (admin) — generated client ---
admin/src/generated/prisma/

# --- Logs & debug ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# --- Test / coverage ---
coverage/
.nyc_output/
*.lcov
.jest/

# --- Caches & tooling ---
.cache/
.parcel-cache/
.eslintcache
.prettiercache
.stylelintcache
*.swp
*.swo
*~

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs ---
.idea/
*.iml
.vscode/

# --- Cursor (local agent/debug state; remove this block if you commit .cursor/rules) ---
.cursor/

# --- Misc ---
*.orig
*.rej
.temporary/
tmp/
temp/
